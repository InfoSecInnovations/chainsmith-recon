  "services": {
    "www": {
      "port": 8082,
      "type": "http",
      "description": "Public website",
      "template": "banking/www"
    },
    "chat": {
      "port": 8081,
      "type": "ai",
      "description": "LLM chatbot API"
    },
    "api": {
      "port": 8080,
      "type": "api",
      "description": "Banking REST API"
    },
    "docs": {
      "port": 8083,
      "type": "http",
      "description": "API documentation",
      "template": "common/docs"
    },
    "mcp": {
      "port": 8089,
      "type": "ai",
      "description": "MCP tool server",
      "template": "ai/mcp_server"
    },
    "agent": {
      "port": 8088,
      "type": "ai",
      "description": "LangServe agent",
      "template": "ai/agent"
    },
    "rag": {
      "port": 8087,
      "type": "ai",
      "description": "RAG knowledge base"
    },
    "cache": {
      "port": 8084,
      "type": "ai",
      "description": "Semantic cache service"
    }
  },
  "vulnerabilities": {
    "summary": "Fakobanko exhibits multiple AI security vulnerabilities across its stack",
    "by_suite": {
      "web": [
        "Missing security headers on www",
        "Sensitive paths in robots.txt",
        "CORS reflects origin on API",
        "OpenAPI spec exposed"
      ],
      "ai": [
        "Prompt leakage on chatbot",
        "No rate limiting",
        "Tools discoverable",
        "Filter bypassable"
      ],
      "mcp": [
        "Critical SQL execution tool",
        "High-risk fund transfer tool",
        "File read with path traversal risk"
      ],
      "agent": [
        "System prompt leaked via injection",
        "Tool disclosure via task pivot",
        "No input validation"
      ],
      "rag": [
        "Context extraction successful",
        "Internal documents exposed",
        "Delimiter escape vulnerable"
      ],
      "cag": [
        "Cross-session data leakage",
        "Predictable context IDs",
        "Cache timing side channel"
      ]
    }
  }
}
